[run]
source = apps,core
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */__init__.py
    */admin.py
    */apps.py
    */venv/*
    */site-packages/*
    */management/commands/*
    apps/graph/services.py
    apps/invoiceinbox/graph_inbox_service.py

[report]
precision = 2
show_missing = True
skip_covered = False

[html]
directory = htmlcov
