# CRM Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# Database Configuration
# ============================================================================
# Local dev (PostgreSQL) — use individual vars OR DATABASE_URL
DB_NAME=crm_backend
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432

# Railway / Heroku-style URL (takes precedence if set)
# Example: postgres://user:pass@host:5432/dbname
# DATABASE_URL=

# ============================================================================
# Cache / Sessions (Redis)
# ============================================================================
# Local dev: redis://localhost:6379/0
# Railway: ${{Redis.REDIS_URL}} (auto-injected by Railway)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Django Settings
# ============================================================================
SECRET_KEY=your-secret-key-here-change-in-production-use-50-chars-minimum
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Session Configuration (30 minutes in seconds)
SESSION_COOKIE_AGE=1800

# ============================================================================
# Security Settings (Development - change for production)
# ============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ============================================================================
# CORS / CSRF (frontend integration)
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# Microsoft Graph API (Office 365 Email Sync + Invoice Inbox)
# ============================================================================
MICROSOFT_CLIENT_ID=your-application-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_TENANT_ID=your-directory-tenant-id-here
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/graph/callback
FRONTEND_URL=http://localhost:3000
