# CRM Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration (PostgreSQL)
DB_NAME=crm_backend
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production-use-50-chars-minimum
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Session Configuration (30 minutes in seconds)
SESSION_COOKIE_AGE=1800

# Security Settings (Development - change for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS Settings (if needed for frontend integration)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Microsoft Graph API (Office 365 Email Sync + Invoice Inbox)
# Get these from Azure Portal → App registrations → Your app
MICROSOFT_CLIENT_ID=your-application-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_TENANT_ID=your-directory-tenant-id-here
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/graph/callback