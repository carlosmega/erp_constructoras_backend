{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "preDeployCommand": "until python manage.py migrate --noinput; do echo 'Postgres not ready, retrying in 5s...'; sleep 5; done",
    "startCommand": "python manage.py collectstatic --noinput && gunicorn crm.wsgi --bind 0.0.0.0:$PORT --workers 3 --access-logfile -",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
